rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Utilisateur régulier (email/password)
    function isRegularUser() {
      return request.auth != null &&
             request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Aide temporaire : anonyme avec une session valide dans tempSessions
    function isTempUser() {
      return request.auth != null &&
             request.auth.token.firebase.sign_in_provider == 'anonymous' &&
             exists(/databases/$(database)/documents/tempSessions/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/tempSessions/$(request.auth.uid)).data.expiresAt
               > request.time.toMillis();
    }

    function hasAccess() {
      return isRegularUser() || isTempUser();
    }

    // ── Profils utilisateurs ──
    match /users/{uid} {
      allow read: if hasAccess();
      // Les réguliers gèrent leur propre profil ; les temps aussi (créé à la connexion)
      allow create, update: if (isRegularUser() || isTempUser()) && request.auth.uid == uid;
      allow delete: if isRegularUser() && request.auth.uid == uid;
    }

    // ── Tâches ──
    // Les aides peuvent lire et compléter (update), pas créer ni supprimer
    match /tasks/{taskId} {
      allow read:          if hasAccess();
      allow create, delete: if isRegularUser();
      allow update:        if hasAccess();
    }

    // ── Épingles carte — aides en lecture seule ──
    match /map_pins/{pinId} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // ── Config — tout auth peut lire (validation du code avant session) ──
    match /config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isRegularUser();
    }

    // ── Alertes — aides en lecture seule ──
    match /alerts/{alertId} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // ── Codes d'accès temporaires ──
    // Tout auth peut lire UN code par son ID (besoin de connaître le code) ; list réservé aux réguliers
    match /tempCodes/{codeId} {
      allow get:   if request.auth != null;
      allow list:  if isRegularUser();
      allow write: if isRegularUser();
    }

    // ── Sessions temporaires ──
    match /tempSessions/{uid} {
      allow get:  if request.auth != null && request.auth.uid == uid;
      allow list: if isRegularUser();
      // Un anonyme peut créer SA session uniquement si le code référencé existe et que l'expiry correspond
      allow create: if request.auth != null &&
                       request.auth.uid == uid &&
                       request.auth.token.firebase.sign_in_provider == 'anonymous' &&
                       exists(/databases/$(database)/documents/tempCodes/$(request.resource.data.codeId)) &&
                       request.resource.data.expiresAt ==
                         get(/databases/$(database)/documents/tempCodes/$(request.resource.data.codeId)).data.expiresAt &&
                       request.resource.data.expiresAt > request.time.toMillis();
      allow delete: if isRegularUser() ||
                       (request.auth != null && request.auth.uid == uid);
    }

    // ── Utilisateurs temporaires (aide sans compte, pour assignation de tâches) ──
    match /tempUsers/{userId} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // ── Animaux individuels ──
    match /animals/{animalId} {
      allow read:   if hasAccess();
      // Création / suppression / modification générale : réguliers uniquement
      allow create, delete: if isRegularUser();
      allow update: if isRegularUser()
                       // Les aides (codes temporaires) peuvent UNIQUEMENT cocher
                       // "vu en bonne santé" sur les animaux — ces 2 champs et
                       // rien d'autre. Permet le suivi terrain par tout le monde.
                       || (isTempUser() &&
                           request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['lastCheckedHealthy', 'lastCheckedHealthyBy']));
    }

    // ── Photos attachées aux épingles ──
    // Tout utilisateur connecté peut voir et ajouter ; suppression réservée à l'auteur ou aux réguliers
    match /pin_photos/{photoId} {
      allow read:   if hasAccess();
      allow create: if hasAccess() && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if isRegularUser() ||
                       (hasAccess() && resource.data.uploadedBy == request.auth.uid);
      allow update: if false;
    }

    // ── Carnet de soins des animaux ──
    // Lecture libre pour tout utilisateur ayant accès ; écriture réservée aux réguliers
    match /animal_care/{careId} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // ── Photos de suivi des animaux (galerie d'évolution) ──
    // Lecture pour tout utilisateur ayant accès. Création par tout utilisateur authentifié
    // (les aides peuvent aussi documenter l'évolution d'un problème). Suppression réservée
    // à l'auteur ou aux réguliers.
    // Update : les tags peuvent être édités par les réguliers (filtrage / catégorisation
    // ultérieure des photos — ex: marquer "pelage_hiver" après coup). Le reste reste immuable.
    match /animal_photos/{photoId} {
      allow read:   if hasAccess();
      allow create: if hasAccess() && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if isRegularUser() ||
                       (hasAccess() && resource.data.uploadedBy == request.auth.uid);
      allow update: if isRegularUser()
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['tags', 'note']);
    }

    // ── Mesures de croissance (poids, taille, ECS…) ──
    // Lecture libre pour tout utilisateur ayant accès, écriture pour les réguliers
    // (saisie chiffrée — pas pour les aides temporaires).
    match /animal_measurements/{mid} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // ── Réserves (foin, paille, granulés, etc.) ──
    // Lecture libre + ajustement quantité par tout utilisateur ; gestion (créer/supprimer) réservée aux réguliers
    match /reserves/{reserveId} {
      allow read:   if hasAccess();
      allow update: if hasAccess();   // permettre les ajustements quotidiens par les aides aussi
      allow create, delete: if isRegularUser();
    }

    // ── Historique des mouvements d'animaux entre enclos ──
    // Lecture libre, création par tout utilisateur ayant accès (auto-log lors d'un changement d'enclos)
    // Pas de update / delete : c'est un log immuable
    match /enclosure_movements/{moveId} {
      allow read:   if hasAccess();
      allow create: if hasAccess();
      allow update, delete: if isRegularUser();
    }

    // ── Optimisation des lectures (système opti) ──
    // Un document unique /opti/state contenant un timestamp par collection.
    // Bumpé après chaque écriture, sert aux clients à éviter de re-fetch
    // une collection inchangée. Tous les authentifiés peuvent lire+écrire.
    match /opti/{docId} {
      allow read, write: if hasAccess();
    }

    // ── Rapports de bugs (capture pendant la phase de test) ──
    // Toute personne authentifiée (y compris codes temporaires) peut créer un rapport.
    // Lecture libre pour tous les authentifiés afin de consulter l'historique.
    // Suppression réservée aux utilisateurs réguliers (nettoyage).
    match /bugReports/{reportId} {
      allow read:   if hasAccess();
      allow create: if hasAccess();
      allow update: if false; // les rapports sont immuables
      allow delete: if isRegularUser();
    }

    // ── Messages ciblés (boîte de réception in-app) ──
    // Utilisé pour répondre aux bugs/questions des utilisatrices sans passer par
    // un canal externe. Le destinataire peut relire à volonté ; il n'y a pas
    // d'archive (pas demandé). Aucune notif push : juste un badge in-app.
    //
    // - create : utilisateurs réguliers uniquement, et fromUid doit être leur propre uid
    //   (anti-spoof). Les aides temporaires ne peuvent pas envoyer de messages.
    // - read : destinataire OU émetteur uniquement (jamais tiers)
    // - update : destinataire uniquement, et uniquement readAt (marquer lu)
    // - delete : destinataire OU émetteur (rangement éventuel)
    match /user_messages/{messageId} {
      allow create: if isRegularUser()
                       && request.resource.data.fromUid == request.auth.uid;
      allow read:   if request.auth != null
                       && (resource.data.toUid == request.auth.uid
                           || resource.data.fromUid == request.auth.uid);
      allow update: if request.auth != null
                       && resource.data.toUid == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['readAt']);
      allow delete: if request.auth != null
                       && (resource.data.toUid == request.auth.uid
                           || resource.data.fromUid == request.auth.uid);
    }

    // ── Réponses au questionnaire d'enrichissement des fiches terrain ──
    // Collection statique de questions générées depuis les fiches papier des
    // terrains (cf app/src/data/parcelQuestions.ts). Les réponses sont saisies
    // par la famille en groupe sur 1 seul compte régulier.
    // - read : tous les authentifiés (transparence des réponses)
    // - write : utilisateurs réguliers uniquement (pas les aides temporaires)
    match /parcel_answers/{questionId} {
      allow read:  if hasAccess();
      allow write: if isRegularUser();
    }

    // Tout le reste : refusé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
